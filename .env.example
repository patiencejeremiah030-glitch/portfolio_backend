SECRET_KEY=your-django-secret-key-here
DEBUG=True
# false = SQLite locally. true = Postgres (required on Render with DATABASE_URL).
USE_POSTGRES=false
# On Render, DATABASE_URL is enough — Postgres is used automatically when RENDER is set.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/portfolio_db
GROQ_API_KEY=
# Optional: auto-create admin on deploy (set on Render only — never commit real values)
# DJANGO_SUPERUSER_USERNAME=
# DJANGO_SUPERUSER_EMAIL=
# DJANGO_SUPERUSER_PASSWORD=
# Comma-separated hosts (add your Render URL in production)
ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated frontend URLs (add your Vercel URL after deploy)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Render: also set your exact Vercel URL (and custom domain if you use one)
# FRONTEND_URL=https://your-app.vercel.app
# CORS_ALLOW_ALL=true
