SECRET_KEY=your-django-secret-key-here
DEBUG=True
# false = SQLite locally (DATABASE_URL is ignored). true = use DATABASE_URL (Render/production).
USE_POSTGRES=false
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/portfolio_db
GROQ_API_KEY=
# Optional: auto-create admin on deploy (set on Render only — never commit real values)
# DJANGO_SUPERUSER_USERNAME=
# DJANGO_SUPERUSER_EMAIL=
# DJANGO_SUPERUSER_PASSWORD=
# Comma-separated hosts (add your Render URL in production)
ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated frontend URLs (add your Vercel URL after deploy)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
